# Server Configuration
HOST=localhost
PORT=3000
NODE_ENV=development

# PostgreSQL Pool Configuration
PG_POOL_MAX=10
PG_IDLE_TIMEOUT=30000
PG_CONNECTION_TIMEOUT=10000

# PostgreSQL Configuration (Lokal dimatikan agar tidak bentrok dengan Supabase)
# PGUSER=postgres
# PGPASSWORD=your_local_password
# PGDATABASE=postgres
# PGHOST=localhost
# PGPORT=5432

# Koneksi Supabase Database (Pastikan password di-URL-encode jika mengandung karakter khusus seperti #)
DATABASE_URL=postgresql://postgres.[YOUR_PROJECT_REF]:[YOUR_PASSWORD]@[YOUR_REGION].pooler.supabase.com:6543/postgres

# JWT Secret untuk Autentikasi
JWT_SECRET=your_super_secret_jwt_key_here

# Gemini AI API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Redis Configuration (Optional - jika kosong, sistem tetap berjalan tanpa Redis)
REDIS_URL=redis://localhost:6379

# Koneksi Supabase Storage (Upload Foto)
SUPABASE_URL=https://[YOUR_PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here