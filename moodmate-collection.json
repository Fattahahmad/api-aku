{
  "info": {
    "name": "MoodMate API - FID Mood & Habit Tracker",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api/v1",
      "type": "string"
    },
    {
      "key": "bearerToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "habitId",
      "value": "",
      "type": "string"
    },
    {
      "key": "completionDate",
      "value": "2026-07-08",
      "type": "string"
    },
    {
      "key": "fromDate",
      "value": "2026-06-07",
      "type": "string"
    },
    {
      "key": "toDate",
      "value": "2026-07-08",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Mood Logs (FID)",
      "item": [
        {
          "name": "POST /logs - Create FID Log",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{bearerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"emotion\": \"Joy\",\n  \"intensity\": 8,\n  \"duration\": 2,\n  \"journal_text\": \"Hari ini ceria karena selesai tugas\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/logs",
              "host": ["{{baseUrl}}", "logs"]
            }
          }
        },
        {
          "name": "GET /logs/today",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{bearerToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/logs/today",
              "host": ["{{baseUrl}}", "logs", "today"]
            }
          }
        },
        {
          "name": "GET /insights/weekly",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{bearerToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/insights/weekly",
              "host": ["{{baseUrl}}", "insights", "weekly"]
            }
          }
        },
        {
          "name": "GET /dashboard/summary",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{bearerToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/dashboard/summary",
              "host": ["{{baseUrl}}", "dashboard", "summary"]
            }
          }
        }
      ]
    },
    {
      "name": "Habits",
      "item": [
        {
          "name": "GET /habits",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{bearerToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/habits",
              "host": ["{{baseUrl}}", "habits"]
            }
          }
        },
        {
          "name": "POST /habits",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{bearerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Olahraga ringan 15 menit\",\n  \"description\": \"Stretching atau jalan pagi\",\n  \"targetDate\": \"2026-07-30\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/habits",
              "host": ["{{baseUrl}}", "habits"]
            }
          }
        },
        {
          "name": "PATCH /habits/:id",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{bearerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Olahraga ringan 20 menit\",\n  \"description\": \"Stretching, jalan pagi, atau yoga ringan\",\n  \"targetDate\": \"2026-07-30\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/habits/{{habitId}}",
              "host": ["{{baseUrl}}", "habits", "{{habitId}}"]
            }
          }
        },
        {
          "name": "DELETE /habits/:id",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{bearerToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/habits/{{habitId}}",
              "host": ["{{baseUrl}}", "habits", "{{habitId}}"]
            }
          }
        },
        {
          "name": "POST /habits/:id/completions",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{bearerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"date\": \"{{completionDate}}\",\n  \"note\": \"Hari ini berhasil\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/habits/{{habitId}}/completions",
              "host": ["{{baseUrl}}", "habits", "{{habitId}}", "completions"]
            }
          }
        },
        {
          "name": "DELETE /habits/:id/completions",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{bearerToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/habits/{{habitId}}/completions?date={{completionDate}}",
              "host": ["{{baseUrl}}", "habits", "{{habitId}}", "completions"],
              "query": [{ "key": "date", "value": "{{completionDate}}" }]
            }
          }
        },
        {
          "name": "GET /habits/summary",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{bearerToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/habits/summary?from={{fromDate}}&to={{toDate}}",
              "host": ["{{baseUrl}}", "habits", "summary"],
              "query": [
                { "key": "from", "value": "{{fromDate}}" },
                { "key": "to", "value": "{{toDate}}" }
              ]
            }
          }
        }
      ]
    }
  ]
}