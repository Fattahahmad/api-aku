            "header": [
              { "key": "Authorization", "value": "Bearer {{bearerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Morning Exercise\",\n  \"description\": \"Stretching for 15 minutes\",\n  \"targetDate\": \"2025-01-31\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/habits",
              "host": ["{{baseUrl}}"],
              "path": ["habits"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.habit && jsonData.data.habit.id) {",
                  "    pm.collectionVariables.set(\"habitId\", jsonData.data.habit.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "2. Get Habits",
          "request": {
            "method": "GET",
