            ],
            "url": {
              "raw": "{{baseUrl}}/habits/{{habitId}}",
              "host": ["{{baseUrl}}"],
              "path": ["habits", "{{habitId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
